{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/2702207741-dev/agent-skills-pipeline/schemas/external-skills.schema.json",
  "title": "our-skills external repository registry",
  "type": "object",
  "required": [
    "project",
    "version",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "version"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
          },
          "description": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1024
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
